@prefix hlb: <http://meaningfy.ws/ontology/hulubul/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hlb:Feedback a sh:NodeShape ;
    rdfs:comment "A reified rating and/or comment left by one participation about another, optionally scoped to a delivery request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class hlb:DeliveryRequest ;
            sh:description "The delivery request the feedback concerns." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path hlb:aboutRequest ],
        [ sh:datatype xsd:integer ;
            sh:description "Numeric score." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:rating ],
        [ sh:class hlb:AgentInRole ;
            sh:description "The participation that authored the feedback." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path hlb:fromProvider ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:class hlb:AgentInRole ;
            sh:description "The participation the feedback is about." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path hlb:toRecipient ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text remark." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:comment ] ;
    sh:targetClass hlb:Feedback .

hlb:SpatialObject a sh:NodeShape ;
    rdfs:comment "Root of the spatial hierarchy (aligned to geo:SpatialObject). Anything with spatial identity that may carry a geometry." ;
    sh:closed false ;
    sh:ignoredProperties ( hlb:locality rdf:type hlb:name hlb:county hlb:country hlb:street hlb:postCode hlb:withinArea hlb:number hlb:hasIdentifier hlb:hasType hlb:state ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text remark or annotation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:comment ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:class hlb:GeoCoordinates ;
            sh:description "The point geometry of this spatial object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path hlb:hasCoordinates ] ;
    sh:targetClass hlb:SpatialObject .

hlb:DeliveryRequest a sh:NodeShape ;
    rdfs:comment "A request to move one or more parcels from a pickup location to a drop-off location, carrying its participants, status and lifecycle timestamps." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:class hlb:Parcel ;
            sh:description "The parcel(s) to be delivered." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path hlb:hasDeliveryItem ],
        [ sh:datatype xsd:dateTime ;
            sh:description "When the request was last modified." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path hlb:updated ],
        [ sh:description "An alternative drop-off location (Address or Place). Owner resolved to request-level per diagram 2 (a Receiver-level variant was drawn in diagram 3 — not modelled here)." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class hlb:Address ] [ sh:class hlb:Place ] ) ;
            sh:order 13 ;
            sh:path hlb:hasAltDropOffLocation ],
        [ sh:class hlb:Transporter ;
            sh:description "The assigned transporter participation, once one is selected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path hlb:hasTransporter ],
        [ sh:class hlb:Sender ;
            sh:description "The sender participation for this request." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path hlb:hasSender ],
        [ sh:description "Current lifecycle status." ;
            sh:in ( hlb:new hlb:needsClarification hlb:complete hlb:optionsProposed hlb:waitingResponse hlb:accepted hlb:rejected hlb:pickUpPlanned hlb:pickedUp hlb:delivered hlb:cancelled ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path hlb:hasStatus ],
        [ sh:datatype xsd:dateTime ;
            sh:description "When the request was created." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path hlb:created ],
        [ sh:description "Where the parcel(s) are collected — an Address or a named Place." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class hlb:Address ] [ sh:class hlb:Place ] ) ;
            sh:order 11 ;
            sh:path hlb:hasPickUpLocation ],
        [ sh:description "Where the parcel(s) are delivered — an Address or a named Place." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class hlb:Address ] [ sh:class hlb:Place ] ) ;
            sh:order 12 ;
            sh:path hlb:hasDropOffLocation ],
        [ sh:class hlb:Receiver ;
            sh:description "The primary receiver participation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path hlb:hasReceiver ],
        [ sh:datatype xsd:dateTime ;
            sh:description "When the request was closed/terminated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path hlb:closed ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text notes attached to the request." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:requestNote ],
        [ sh:datatype xsd:string ;
            sh:description "The requester's preferred timeframe (orientative, free text)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:preferredPeriod ] ;
    sh:targetClass hlb:DeliveryRequest .

hlb:Parcel a sh:NodeShape ;
    rdfs:comment "A physical item to be delivered as part of a request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URLs of photos of the parcel." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path hlb:photoURL ],
        [ sh:datatype xsd:string ;
            sh:description "The sender's declared description of contents." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:declaredContent ],
        [ sh:datatype xsd:float ;
            sh:description "Weight in kilograms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path hlb:weightKg ],
        [ sh:class hlb:Receiver ;
            sh:description "An alternative receiver for this specific parcel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path hlb:hasAltReceiver ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text dimensions (e.g. \"30x20x10 cm\")." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path hlb:dimensions ] ;
    sh:targetClass hlb:Parcel .

hlb:Sender a sh:NodeShape ;
    rdfs:comment "The role of the agent that initiates a delivery request and hands over the parcel(s). The sender also names the receiver." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class hlb:Agent ;
            sh:description "The enduring agent enacting this role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path hlb:playedBy ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:class hlb:Channel ;
            sh:description "An alternative channel to use for this participation, overriding the agent's default." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path hlb:hasAltContactPointInRole ] ;
    sh:targetClass hlb:Sender .

hlb:TransportService a sh:NodeShape ;
    rdfs:comment "A standing, request-agnostic offering published by a transporter agent, declaring service types and its base and destination service areas." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Short title of the offering." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:serviceTitle ],
        [ sh:class hlb:ServiceOffer ;
            sh:description "Pickup footprint — areas (with frequency) where the transporter can collect." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path hlb:hasBaseArea ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:description ],
        [ sh:description "What the service carries (people and/or parcels)." ;
            sh:in ( hlb:peopleTransport hlb:parcelTransport ) ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path hlb:serviceType ],
        [ sh:class hlb:ServiceOffer ;
            sh:description "Delivery reach — areas (with frequency) the transporter serves as destinations." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path hlb:hasDestinationArea ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ] ;
    sh:targetClass hlb:TransportService .

hlb:Transporter a sh:NodeShape ;
    rdfs:comment "The role of the agent that carries the parcel(s) for a delivery request." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:class hlb:Agent ;
            sh:description "The enduring agent enacting this role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path hlb:playedBy ],
        [ sh:class hlb:Channel ;
            sh:description "An alternative channel to use for this participation, overriding the agent's default." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path hlb:hasAltContactPointInRole ] ;
    sh:targetClass hlb:Transporter .

hlb:AgentInRole a sh:NodeShape ;
    rdfs:comment "The episodic, situation-dependent role an Agent plays within a specific interaction; a reified participation. Anti-rigid: the same Agent plays different roles across different requests." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type hlb:deliveryNote ) ;
    sh:property [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:class hlb:Channel ;
            sh:description "An alternative channel to use for this participation, overriding the agent's default." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path hlb:hasAltContactPointInRole ],
        [ sh:class hlb:Agent ;
            sh:description "The enduring agent enacting this role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path hlb:playedBy ] ;
    sh:targetClass hlb:AgentInRole .

hlb:Receiver a sh:NodeShape ;
    rdfs:comment "The role of the agent intended to take delivery of the parcel(s)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A note from or for the receiver regarding delivery (e.g. handover instructions)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path hlb:deliveryNote ],
        [ sh:class hlb:Agent ;
            sh:description "The enduring agent enacting this role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path hlb:playedBy ],
        [ sh:class hlb:Channel ;
            sh:description "An alternative channel to use for this participation, overriding the agent's default." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path hlb:hasAltContactPointInRole ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path hlb:id ] ;
    sh:targetClass hlb:Receiver .

hlb:ServiceOffer a sh:NodeShape ;
    rdfs:comment "A served area paired with an orientative frequency. The same shape serves both base and destination offers; direction is given by which association (hasBaseArea vs hasDestinationArea) it sits under, not by a flag. Given an id (graph node) because it carries an outgoing edge to Area." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:description ],
        [ sh:class hlb:Area ;
            sh:description "The area this object sits within." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path hlb:withinArea ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:description "How often the transporter is in/through the area (orientative)." ;
            sh:in ( hlb:daily hlb:weekly hlb:biweekly hlb:fortnightly hlb:monthly ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path hlb:withFrequency ] ;
    sh:targetClass hlb:ServiceOffer .

hlb:Place a sh:NodeShape ;
    rdfs:comment "A named, typed point/place of interest (landmark, depot, pickup point) sitting within an Area. Distinct from coarse Area and precise Address." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Identifier of the place (e.g. gazetteer id)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:hasIdentifier ],
        [ sh:datatype xsd:string ;
            sh:description "Type of the place (e.g. depot, landmark, pickup point)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path hlb:hasType ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name of the place." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:name ],
        [ sh:class hlb:Area ;
            sh:description "The area this object sits within." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:withinArea ],
        [ sh:class hlb:GeoCoordinates ;
            sh:description "The point geometry of this spatial object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path hlb:hasCoordinates ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path hlb:id ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text remark or annotation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path hlb:comment ] ;
    sh:targetClass hlb:Place .

hlb:Address a sh:NodeShape ;
    rdfs:comment "A precise, pin-level postal address." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "House/building number." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:number ],
        [ sh:datatype xsd:string ;
            sh:description "Postal code." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path hlb:postCode ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text remark or annotation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path hlb:comment ],
        [ sh:class hlb:Area ;
            sh:description "The area this object sits within." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:withinArea ],
        [ sh:class hlb:GeoCoordinates ;
            sh:description "The point geometry of this spatial object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path hlb:hasCoordinates ],
        [ sh:datatype xsd:string ;
            sh:description "Street name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:street ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path hlb:id ] ;
    sh:targetClass hlb:Address .

hlb:Agent a sh:NodeShape ;
    rdfs:comment "An enduring party — a person or an organisation — that participates in Hulubul. Holds stable identity, communication channels, an optional main location, and may publish a standing transport service and play episodic roles." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:name ],
        [ sh:class hlb:Channel ;
            sh:description "Communication channels through which the agent can be reached and, when validated, authenticated." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path hlb:hasContactPoint ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:class hlb:Address ;
            sh:description "The agent's principal location." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path hlb:hasMainLocation ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:description ],
        [ sh:class hlb:Channel ;
            sh:description "The agent's primary/default channel; also the trusted login channel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path hlb:hasMainContactPoint ],
        [ sh:class hlb:TransportService ;
            sh:description "The standing, request-agnostic transport offering published by this agent (present only for transporters)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path hlb:providesService ],
        [ sh:datatype xsd:string ;
            sh:description "Stable unique business identifier of the agent within Hulubul." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path hlb:identifier ] ;
    sh:targetClass hlb:Agent .

hlb:Area a sh:NodeShape ;
    rdfs:comment "A coarse administrative or geographic unit (locality, county, state, country) forming a nested containment hierarchy. Transporter service offers and matching operate on Area; exact pickup/delivery use Address." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class hlb:GeoCoordinates ;
            sh:description "The point geometry of this spatial object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path hlb:hasCoordinates ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text remark or annotation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path hlb:comment ],
        [ sh:datatype xsd:string ;
            sh:description "County/district (raion)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:county ],
        [ sh:datatype xsd:string ;
            sh:description "Country name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path hlb:country ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path hlb:id ],
        [ sh:class hlb:Area ;
            sh:description "The area this object sits within." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:withinArea ],
        [ sh:datatype xsd:string ;
            sh:description "State/region within country." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path hlb:state ],
        [ sh:datatype xsd:string ;
            sh:description "Town/city/locality name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:locality ] ;
    sh:targetClass hlb:Area .

hlb:GeoCoordinates a sh:NodeShape ;
    rdfs:comment "A WGS84 latitude/longitude point — the geometry attached to a spatial object (GeoSPARQL geo:Geometry analogue). Composed value object, inlined (no id) rather than a node." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description "WGS84 latitude." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path hlb:latitude ],
        [ sh:datatype xsd:float ;
            sh:description "WGS84 longitude." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:longitude ] ;
    sh:targetClass hlb:GeoCoordinates .

hlb:Channel a sh:NodeShape ;
    rdfs:comment "A communication channel bound to a single agent — the endpoint through which the agent is reached and, when validated, authenticated." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Phone number, when the medium is phone-based." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path hlb:telephone ],
        [ sh:datatype xsd:string ;
            sh:description "Email address, when the medium is email." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path hlb:email ],
        [ sh:description "Graph node identity for this instance (distinct from any business identifier)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path hlb:id ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path hlb:description ],
        [ sh:description "Whether control of the channel has been verified." ;
            sh:in ( hlb:valid hlb:invalid hlb:needsReview ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path hlb:validationStatus ],
        [ sh:datatype xsd:string ;
            sh:description "Human label for the channel (e.g. \"mum's WhatsApp\")." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path hlb:alias ],
        [ sh:datatype xsd:string ;
            sh:description "Provider/platform-issued identifier (e.g. Telegram chat/user id)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path hlb:systemID ],
        [ sh:description "The medium/platform of this channel." ;
            sh:in ( hlb:GSM hlb:WhatsApp hlb:Telegram hlb:Viber hlb:email ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path hlb:hasMedium ] ;
    sh:targetClass hlb:Channel .


