{
  "$defs": {
    "ActorContext": {
      "additionalProperties": false,
      "description": "Trusted actor context (metadata only, no secrets).",
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_role": {
          "$ref": "#/$defs/ActorRole",
          "default": "sender"
        },
        "display_name": {
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "identity_assurance": {
          "$ref": "#/$defs/IdentityAssurance",
          "default": "simulated"
        }
      },
      "required": [
        "actor_id",
        "display_name"
      ],
      "title": "ActorContext",
      "type": "object"
    },
    "ActorRole": {
      "description": "Actor role.",
      "enum": [
        "sender"
      ],
      "title": "ActorRole",
      "type": "string"
    },
    "BindingState": {
      "description": "Binding state.",
      "enum": [
        "absent",
        "bound",
        "inconsistent"
      ],
      "title": "BindingState",
      "type": "string"
    },
    "ErrorCategory": {
      "description": "Error category for logging.",
      "enum": [
        "input",
        "contract",
        "authorization",
        "state",
        "concurrency",
        "dependency",
        "internal"
      ],
      "title": "ErrorCategory",
      "type": "string"
    },
    "ErrorCode": {
      "description": "Operational error codes.",
      "enum": [
        "INVALID_INPUT",
        "INVALID_CONTRACT",
        "OPERATION_NOT_ALLOWED",
        "BINDING_REQUEST_MISMATCH",
        "GRAPH_CONTEXT_INCONSISTENT",
        "UNSUPPORTED_PHASE1_STATUS",
        "UNSUPPORTED_REQUEST_STATUS",
        "INVALID_EXPECTED_STATUS",
        "INVALID_STATUS_TRANSITION",
        "CONCURRENT_MODIFICATION",
        "AFFECTED_RECORD_COUNT_MISMATCH",
        "MODEL_TRANSIENT_FAILURE",
        "MODEL_AUTHENTICATION_FAILURE",
        "MALFORMED_AGENT_RESULT",
        "MCP_READ_TRANSIENT_FAILURE",
        "MCP_WRITE_AMBIGUOUS",
        "MCP_AUTHENTICATION_FAILURE",
        "MCP_OPERATION_FAILURE",
        "DEPENDENCY_UNAVAILABLE"
      ],
      "title": "ErrorCode",
      "type": "string"
    },
    "FieldViolation": {
      "maxItems": 2,
      "minItems": 2,
      "prefixItems": [
        {
          "title": "Field Path",
          "type": "string"
        },
        {
          "title": "Rule Id",
          "type": "string"
        }
      ],
      "type": "array"
    },
    "IdentityAssurance": {
      "description": "Identity assurance level.",
      "enum": [
        "simulated"
      ],
      "title": "IdentityAssurance",
      "type": "string"
    },
    "InvocationSource": {
      "description": "Flow invocation source.",
      "enum": [
        "api",
        "playground"
      ],
      "title": "InvocationSource",
      "type": "string"
    },
    "MainFlowInput": {
      "additionalProperties": false,
      "description": "Main flow input with trusted envelope and user message.",
      "properties": {
        "actor": {
          "$ref": "#/$defs/ActorContext"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "message": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "message_id": {
          "format": "uuid",
          "title": "Message Id",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "session_id": {
          "minLength": 1,
          "title": "Session Id",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/InvocationSource"
        }
      },
      "required": [
        "correlation_id",
        "message_id",
        "session_id",
        "actor",
        "source",
        "message"
      ],
      "title": "MainFlowInput",
      "type": "object"
    },
    "OperationalError": {
      "additionalProperties": false,
      "description": "Canonical operational error with enforced policy values.",
      "properties": {
        "category": {
          "$ref": "#/$defs/ErrorCategory",
          "description": "Error category (from policy)"
        },
        "code": {
          "$ref": "#/$defs/ErrorCode",
          "description": "Error code"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "message": {
          "description": "Safe user message (from policy)",
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "description": "Whether error is retryable (from policy)",
          "title": "Retryable",
          "type": "boolean"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "violations": {
          "description": "Validation violations (field and rule ID only, no values)",
          "items": {
            "$ref": "#/$defs/FieldViolation"
          },
          "title": "Violations",
          "type": "array"
        }
      },
      "required": [
        "correlation_id",
        "code",
        "category",
        "message",
        "retryable"
      ],
      "title": "OperationalError",
      "type": "object"
    },
    "RequestStatus": {
      "description": "Request lifecycle status.",
      "enum": [
        "new",
        "needsClarification",
        "complete",
        "optionsProposed",
        "waitingResponse",
        "accepted",
        "rejected",
        "pickUpPlanned",
        "pickedUp",
        "delivered",
        "cancelled"
      ],
      "title": "RequestStatus",
      "type": "string"
    },
    "RoutingContext": {
      "additionalProperties": false,
      "description": "Result of routing lookup adaptation.",
      "properties": {
        "active_relationship_count": {
          "title": "Active Relationship Count",
          "type": "integer"
        },
        "active_target_count": {
          "title": "Active Target Count",
          "type": "integer"
        },
        "binding_count": {
          "title": "Binding Count",
          "type": "integer"
        },
        "binding_state": {
          "$ref": "#/$defs/BindingState"
        },
        "closed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Closed At"
        },
        "correlation_id": {
          "format": "uuid",
          "title": "Correlation Id",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperationalError"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "request_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Request Id"
        },
        "request_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/RequestStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "routing_stage": {
          "$ref": "#/$defs/RoutingStage"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "session_id": {
          "minLength": 1,
          "title": "Session Id",
          "type": "string"
        }
      },
      "required": [
        "correlation_id",
        "session_id",
        "binding_state",
        "binding_count",
        "active_relationship_count",
        "active_target_count",
        "routing_stage"
      ],
      "title": "RoutingContext",
      "type": "object"
    },
    "RoutingStage": {
      "description": "Request routing stage.",
      "enum": [
        "intake",
        "complete",
        "closed",
        "unsupported",
        "failure"
      ],
      "title": "RoutingStage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Input wrapper for routing operations.\n\nCombines MainFlowInput envelope with routing context lookup result.\nEnforces matching schema_version, correlation_id, and session_id across wrapper and nested objects.",
  "properties": {
    "correlation_id": {
      "format": "uuid",
      "title": "Correlation Id",
      "type": "string"
    },
    "envelope": {
      "$ref": "#/$defs/MainFlowInput"
    },
    "routing_context": {
      "$ref": "#/$defs/RoutingContext"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "correlation_id",
    "envelope",
    "routing_context"
  ],
  "title": "RouterInput",
  "type": "object"
}
