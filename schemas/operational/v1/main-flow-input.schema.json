{
  "$defs": {
    "ActorContext": {
      "additionalProperties": false,
      "description": "Trusted actor context (metadata only, no secrets).",
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_role": {
          "$ref": "#/$defs/ActorRole",
          "default": "sender"
        },
        "display_name": {
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "identity_assurance": {
          "$ref": "#/$defs/IdentityAssurance",
          "default": "simulated"
        }
      },
      "required": [
        "actor_id",
        "display_name"
      ],
      "title": "ActorContext",
      "type": "object"
    },
    "ActorRole": {
      "description": "Actor role.",
      "enum": [
        "sender"
      ],
      "title": "ActorRole",
      "type": "string"
    },
    "IdentityAssurance": {
      "description": "Identity assurance level.",
      "enum": [
        "simulated"
      ],
      "title": "IdentityAssurance",
      "type": "string"
    },
    "InvocationSource": {
      "description": "Flow invocation source.",
      "enum": [
        "api",
        "playground"
      ],
      "title": "InvocationSource",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Main flow input with trusted envelope and user message.",
  "properties": {
    "actor": {
      "$ref": "#/$defs/ActorContext"
    },
    "correlation_id": {
      "format": "uuid",
      "title": "Correlation Id",
      "type": "string"
    },
    "message": {
      "maxLength": 4000,
      "minLength": 1,
      "title": "Message",
      "type": "string"
    },
    "message_id": {
      "format": "uuid",
      "title": "Message Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "session_id": {
      "minLength": 1,
      "title": "Session Id",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/InvocationSource"
    }
  },
  "required": [
    "correlation_id",
    "message_id",
    "session_id",
    "actor",
    "source",
    "message"
  ],
  "title": "MainFlowInput",
  "type": "object"
}
