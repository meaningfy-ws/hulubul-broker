POSTGRES_PASSWORD=changeme
# Login/auth disabled — Langflow auto-login is enabled in docker-compose.yaml.
# LANGFLOW_SUPERUSER_USERNAME=admin
# LANGFLOW_SUPERUSER_PASSWORD=changeme

# ---- Neo4j (graph system of record, ADR-005) ----
# Initial password for the `neo4j` user. Must be >= 8 characters.
NEO4J_PASSWORD=changeme123
NEO4J_USERNAME=neo4j
NEO4J_DATABASE=neo4j
# Host port for the MCP server (streamable HTTP).
NEO4J_MCP_PORT=8000
# Read-only flag for the MCP server: true = only read queries; false = writable.
# Default false = admin-style path (ADR-007/015): unguarded, audited, no RBAC on
# Neo4j Community. Set true to lock the server to read-only queries.
NEO4J_MCP_READ_ONLY=false
