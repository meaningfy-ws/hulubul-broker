POSTGRES_PASSWORD=changeme
# Login/auth disabled — Langflow auto-login is enabled in docker-compose.yaml.
# LANGFLOW_SUPERUSER_USERNAME=admin
# LANGFLOW_SUPERUSER_PASSWORD=changeme

# ---- LangFlow (low-code agent orchestration, ADR-016) ----
# API key for programmatic LangFlow API access (required for Task 28 / 6.4).
# Set this to any non-empty value for local dev (e.g., "local-dev-key-xyz").
# Programmatic API calls must include "Authorization: Bearer <key>" header.
# Playground UI auto-login ignores this (still enabled via LANGFLOW_AUTO_LOGIN).
LANGFLOW_API_KEY=local-dev-key-xyz
# Optional playground-only actor context (UI display only, ignored by API).
# These values are read by the UI for default actor context, but are NOT
# sent to the graph or used in API request validation.
HULUBUL_PHASE1_PLAYGROUND_ACTOR_ID=dev-user-001
HULUBUL_PHASE1_PLAYGROUND_ACTOR_DISPLAY_NAME=Dev User

# ---- Neo4j (graph system of record, ADR-005) ----
# Initial password for the `neo4j` user. Must be >= 8 characters.
NEO4J_PASSWORD=changeme123
NEO4J_USERNAME=neo4j
NEO4J_DATABASE=neo4j
# Host port for the MCP server (streamable HTTP).
NEO4J_MCP_PORT=8000
# Read-only flag for the MCP server: true = only read queries; false = writable.
# Default false = admin-style path (ADR-007/015): unguarded, audited, no RBAC on
# Neo4j Community. Set true to lock the server to read-only queries.
NEO4J_MCP_READ_ONLY=false
